# FBE decrypt services for Nothing Phone 3 (Metroid)
# wrappedkey_v0 + inlinecrypt + aes-256-xts:aes-256-cts:v2
# Chain: qseecomd -> listeners.registered -> gatekeeper -> keymaster-4-0 -> vold decrypt

# Override keystore2 - the stock one crashes in recovery (SIGSEGV at startup)
# Use /tmp instead of /data/misc/keystore
service keystore2 /system/bin/keystore2 /tmp/misc/keystore
    user root
    group root keystore readproc log
    disabled
    override
    seclabel u:r:recovery:s0

# Override servicemanager - not needed in recovery, disable autostart
service servicemanager /system/bin/servicemanager
    disabled
    override

on property:ro.crypto.state=encrypted && property:ro.crypto.type=file
    install_keyring
    mkdir /tmp/misc/keystore 0700 root root

# Step 1: start qseecomd (QSEE daemon - needed for TrustZone/keymaster)
service vendor.qseecomd /vendor/bin/qseecomd
    user root
    group root drmrpc
    setenv LD_LIBRARY_PATH /vendor/lib64:/system/lib64
    disabled
    seclabel u:r:recovery:s0

# Step 2: gatekeeper (starts after listeners.registered=true)
service gatekeeper-1-0 /vendor/bin/hw/android.hardware.gatekeeper-service-qti
    user root
    group root
    setenv LD_LIBRARY_PATH /vendor/lib64:/system/lib64
    disabled
    seclabel u:r:recovery:s0

# Step 3: keymaster 4.0 (wrappedkey unwrap)
service keymaster-4-0 /vendor/bin/hw/android.hardware.keymaster@4.0-service-qti
    user root
    group root drmrpc
    setenv LD_LIBRARY_PATH /vendor/lib64:/system/lib64
    disabled
    seclabel u:r:recovery:s0

# Keystore auth
service keystore_auth /system/bin/keystore_auth
    oneshot
    user system
    group root
    disabled
    seclabel u:r:recovery:s0

service keystore /system/bin/keystore /tmp/misc/keystore
    user root
    group root drmrpc readproc log
    disabled
    seclabel u:r:recovery:s0

# Launch chain
on property:ro.crypto.state=encrypted && property:ro.crypto.type=file
    start vendor.qseecomd

on property:vendor.sys.listeners.registered=true
    start gatekeeper-1-0
    start keymaster-4-0

# After decrypt - stop the services
on property:twrp.all.users.decrypted=true
    setprop crypto.ready 0
    stop vendor.qseecomd
    stop gatekeeper-1-0
    stop keymaster-4-0
